# Connector Configuration
# Copy to connectors.yaml and fill in your settings.
# Credentials should be set via environment variables, not in this file.

teams:
  enabled: false
  sync_interval_minutes: 30
  # Only fetch transcripts from meetings on or after this date on the initial sync.
  # Has no effect on subsequent incremental syncs. Recommended to avoid importing all history.
  # transcript_lookback_date: "2024-01-01"
  # MS Graph credentials via env: MS_TENANT_ID, MS_CLIENT_ID, MS_CLIENT_SECRET

outlook:
  enabled: false
  sync_interval_minutes: 15
  folders:
    - Inbox
    - Sent Items
  # Only fetch emails on or after this date on the initial sync (server-side filter).
  # Recommended: set to a date 1-3 years back to avoid ingesting your entire mailbox.
  # email_lookback_date: "2024-01-01"
  # Only fetch calendar events on or after this date (overrides the lookback half of calendar_window_days).
  # calendar_lookback_date: "2024-01-01"
  # MS Graph credentials shared with Teams connector

obsidian:
  enabled: false
  vault_path: ~/Documents/Obsidian
  sync_interval_minutes: 5
  exclude_patterns:
    - ".obsidian/"
    - ".trash/"
    - "templates/"

jira:
  enabled: false
  base_url: https://your-instance.atlassian.net
  sync_interval_minutes: 30
  jql_filter: "assignee = currentUser() ORDER BY updated DESC"
  # Credentials via env: JIRA_EMAIL, JIRA_API_TOKEN

apple_notes:
  enabled: false
  sync_interval_minutes: 15
  # No credentials needed — uses macOS AppleScript bridge
